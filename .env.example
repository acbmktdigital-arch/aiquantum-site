# GEMINI_API_KEY: chave da API do Google Gemini, usada para gerar o
# relatório personalizado do diagnóstico Raio-X.
# Obtenha em https://aistudio.google.com/apikey
# Sem ela, o quiz funciona normalmente com um relatório padrão (fallback).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APPS_SCRIPT_URL: URL do Google Apps Script vinculado à planilha de leads.
# Responsável por salvar cada lead na planilha e enviar o relatório por
# e-mail ao consultor quando o lead pede a Sessão 1A1.
# Veja o passo a passo em GOOGLE_SHEETS_SETUP.md
APPS_SCRIPT_URL="https://script.google.com/macros/s/SEU_ID_AQUI/exec"
